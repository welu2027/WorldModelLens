{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Case Study: DreamerV3 Analysis\n",
    "\n",
    "This notebook provides a comprehensive case study analyzing the DreamerV3 world model using world_model_lens. We'll load the model, analyze its internal activations, perform patching experiments, and interpret the learned representations.\n",
    "\n",
    "## Overview\n",
    "- Load and configure DreamerV3 model\n",
    "- Analyze internal activations and representations\n",
    "- Perform causal patching experiments\n",
    "- Interpret model behaviors and learned concepts"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Setup and imports\n",
    "import torch\n",
    "import numpy as np\n",
    "from world_model_lens import HookedWorldModel, DreamerV3Adapter\n",
    "from world_model_lens.analysis.activation_analysis import ActivationAnalyzer\n",
    "from world_model_lens.patching.causal_tracer import CausalTracer\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "torch.manual_seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "print(\"DreamerV3 Case Study environment setup complete\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load DreamerV3 Model\n",
    "\n",
    "Load a pretrained DreamerV3 model and wrap it with the world_model_lens interface."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load DreamerV3 model\n",
    "model = HookedWorldModel.from_pretrained(\"dreamerv3 Atari\")\n",
    "\n",
    "# Wrap with DreamerV3 adapter for specialized analysis\n",
    "dreamer_adapter = DreamerV3Adapter(model)\n",
    "\n",
    "# Get model architecture info\n",
    "arch_info = dreamer_adapter.get_architecture_info()\n",
    "\n",
    "print(\"DreamerV3 Model Loaded!\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Model type: DreamerV3\")\n",
    "print(f\"Environment: {arch_info['env_name']}\")\n",
    "print(f\"\\nArchitecture components:\")\n",
    "for component, details in arch_info[\"components\"].items():\n",
    "    print(f\"  {component}: {details}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get list of hookable layers\n",
    "hookable_layers = dreamer_adapter.get_hookable_layers()\n",
    "\n",
    "print(f\"Hookable layers ({len(hookable_layers)} total):\")\n",
    "for layer in hookable_layers:\n",
    "    print(f\"  - {layer}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Collect and Analyze Activations\n",
    "\n",
    "Run the model on sample trajectories and collect internal activations for analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create sample trajectories\n",
    "from world_model_lens.utils.data_utils import AtariTrajectoryDataset\n",
    "\n",
    "dataset = AtariTrajectoryDataset(\n",
    "    num_trajectories=100,\n",
    "    trajectory_length=32,\n",
    "    env_name=\"Pong\"\n",
    ")\n",
    "\n",
    "# Initialize activation analyzer\n",
    "analyzer = ActivationAnalyzer(model)\n",
    "\n",
    "# Collect activations on sample trajectories\n",
    "print(\"Collecting activations...\")\n",
    "activation_data = analyzer.collect_activations(\n",
    "    dataset=dataset,\n",
    "    layers=[\n",
    "        \"encoder.conv1\",\n",
    "        \"encoder.conv2\",\n",
    "        \"encoder.fc\",\n",
    "        \"rssm.stochastic\",\n",
    "        \"rssm.deterministic\",\n",
    "        \"decoder.fc\",\n",
    "        \"decoder.conv1\",\n",
    "        \"decoder.conv2\"\n",
    "    ],\n",
    "    batch_size=32\n",
    ")\n",
    "\n",
    "print(f\"Collected activations from {len(activation_data)} layers\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze activation statistics\n",
    "print(\"\\nActivation Statistics:\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "for layer_name, stats in activation_data[\"statistics\"].items():\n",
    "    print(f\"\\n{layer_name}:\")\n",
    "    print(f\"  Shape: {stats['shape']}\")\n",
    "    print(f\"  Mean: {stats['mean']:.4f}\")\n",
    "    print(f\"  Std: {stats['std']:.4f}\")\n",
    "    print(f\"  Sparsity: {stats['sparsity']:.2%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize activation patterns\n",
    "fig, axes = plt.subplots(2, 4, figsize=(16, 8))\n",
    "axes = axes.flatten()\n",
    "\n",
    "layer_names = list(activation_data[\"statistics\"].keys())\n",
    "\n",
    "for idx, layer_name in enumerate(layer_names):\n",
    "    ax = axes[idx]\n",
    "    activations = activation_data[\"activations\"][layer_name]\n",
    "    \n",
    "    # Show distribution of mean activations\n",
    "    mean_activations = np.mean(activations, axis=(0, 1))\n",
    "    ax.hist(mean_activations.flatten(), bins=50, color=\"#3498db\", alpha=0.7)\n",
    "    ax.set_xlabel(\"Activation Value\")\n",
    "    ax.set_ylabel(\"Count\")\n",
    "    ax.set_title(layer_name.split(\".\")[-1])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"activation_distributions.png\", dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type":="code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze RSSM state space\n",
    "print(\"\\nRSSM State Space Analysis:\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "stoch_activations = activation_data[\"activations\"][\"rssm.stochastic\"]\n",
    "det_activations = activation_data[\"activations\"][\"rssm.deterministic\"]\n",
    "\n",
    "# Compute state statistics\n",
    "stoch_unique = len(np.unique(np.round(stoch_activations, 2)))\n",
    "print(f\"Stochastic state unique values: {stoch_unique}\")\n",
    "print(f\"Stochastic state entropy: {analyzer.compute_entropy(stoch_activations):.4f}\")\n",
    "\n",
    "# Analyze determinism\n",
    "det_variance = np.var(det_activations)\n",
    "print(f\"Deterministic state variance: {det_variance:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Patching and Tracing Experiments\n",
    "\n",
    "Perform causal patching experiments to understand which components drive specific behaviors."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize causal tracer for DreamerV3\n",
    "tracer = CausalTracer(model)\n",
    "\n",
    "# Configure tracing experiment\n",
    "from world_model_lens.patching.causal_tracer import TraceConfig\n",
    "\n",
    "trace_config = TraceConfig(\n",
    "    prompt=\"agent observes ball approaching paddle\",\n",
    "    target_behavior=\"predicts_high_reward\",\n",
    "    metric=\"kl_divergence\"\n",
    ")\n",
    "\n",
    "# Run trace\n",
    "print(\"Running causal trace experiment...\")\n",
    "trace_result = tracer.trace(trace_config)\n",
    "\n",
    "print(\"Causal trace complete!\")\n",
    "print(f\"Layers traced: {len(trace_result.layer_effects)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize causal effects\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Bar chart of causal effects\n",
    "ax1 = axes[0]\n",
    "layers = list(trace_result.layer_effects.keys())\n",
    "effects = [trace_result.layer_effects[l] for l in layers]\n",
    "colors = [\"#2ecc71\" if e > 0 else \"#e74c3c\" for e in effects]\n",
    "ax1.barh(layers, effects, color=colors)\n",
    "ax1.set_xlabel(\"Causal Effect (KL Divergence)\")\n",
    "ax1.set_title(\"Causal Effect by Layer\")\n",
    "ax1.axvline(x=0, color=\"black\", linestyle=\"-\", linewidth=0.5)\n",
    "\n",
    "# Heatmap of intervention effects\n",
    "ax2 = axes[1]\n",
    "if hasattr(trace_result, \"intervention_matrix\"):\n",
    "    sns.heatmap(trace_result.intervention_matrix, ax=ax2, cmap=\"coolwarm\", center=0)\n",
    "    ax2.set_title(\"Intervention Effect Matrix\")\n",
    "    ax2.set_xlabel(\"Intervention Layer\")\n",
    "    ax2.set_ylabel(\"Target Layer\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"causal_trace_results.png\", dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Patch specific components to test causal relationships\n",
    "from world_model_lens.patching.patcher import Patcher\n",
    "\n",
    "patcher = Patcher(model)\n",
    "\n",
    "# Experiment 1: Ablate stochastic states\n",
    "print(\"Experiment 1: Stochastic State Ablation\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "clean_output = model(dataset[0][\"observations\"], dataset[0][\"actions\"])\n",
    "\n",
    "ablated_output = patcher.ablate_layer(\n",
    "    layer=\"rssm.stochastic\",\n",
    "    inputs=dataset[0][\"observations\"],\n",
    "    actions=dataset[0][\"actions\"],\n",
    "    ablation_type=\"zero\"\n",
    ")\n",
    "\n",
    "print(f\"Clean output reward pred: {clean_output['reward_pred'].mean():.4f}\")\n",
    "print(f\"Ablated output reward pred: {ablated_output['reward_pred'].mean():.4f}\")\n",
    "print(f\"Difference: {clean_output['reward_pred'].mean() - ablated_output['reward_pred'].mean():.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Experiment 2: Replace deterministic states\n",
    "print(\"\\nExperiment 2: Deterministic State Replacement\")\n",
    "print(\"-\"*40)\n",
    "\n",
    "# Get two different observations\n",
    "obs1 = dataset[0][\"observations\"]\n",
    "obs2 = dataset[5][\"observations\"]\n",
    "\n",
    "# Run with different observations but same actions\n",
    "output1 = model(obs1, dataset[0][\"actions\"])\n",
    "output2 = model(obs2, dataset[0][\"actions\"])\n",
    "\n",
    "# Replace deterministic state from obs2 into obs1\n",
    "replaced_output = patcher.replace_layer(\n",
    "    layer=\"rssm.deterministic\",\n",
    "    original_inputs=obs1,\n",
    "    replacement_inputs=obs2,\n",
    "    actions=dataset[0][\"actions\"]\n",
    ")\n",
    "\n",
    "print(f\"Original obs1 latent: {output1['latent'][:5]}\")\n",
    "print(f\"Original obs2 latent: {output2['latent'][:5]}\")\n",
    "print(f\"After deterministic replacement: {replaced_output['latent'][:5]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Interpret Model Behavior\n",
    "\n",
    "Analyze what the model has learned and how it represents different concepts."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze concept representations using DreamerV3 adapter\n",
    "print(\"Concept Representation Analysis\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "concept_analysis = dreamer_adapter.analyze_concepts(dataset)\n",
    "\n",
    "for concept, details in concept_analysis.items():\n",
    "    print(f\"\\n{concept}:\")\n",
    "    print(f\"  Activation pattern: {details.get('activation_pattern', 'N/A')}\")\n",
    "    print(f\"  Importance: {details.get('importance', 0):.4f}\")\n",
    "    print(f\"  Location: {details.get('primary_location', 'unknown')}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze imagination capabilities\n",
    "print(\"\\nImagination Analysis\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Get initial state from real observation\n",
    "initial_obs = dataset[0][\"observations\"]\n",
    "initial_action = dataset[0][\"actions\"][:1]\n",
    "\n",
    "# Run imagination rollouts\n",
    "imagination_results = dreamer_adapter.imagine_rollout(\n",
    "    initial_obs=initial_obs,\n",
    "    actions=initial_action,\n",
    "    horizon=50,\n",
    "    num_samples=10\n",
    ")\n",
    "\n",
    "print(f\"Imagined horizon: {imagination_results['horizon']} steps\")\n",
    "print(f\"Number of samples: {imagination_results['num_samples']}\")\n",
    "print(f\"Reward trajectory shape: {imagination_results['rewards'].shape}\")\n",
    "print(f\"Mean imagined reward: {imagination_results['rewards'].mean():.4f}\")\n",
    "print(f\"Reward variance: {imagination_results['rewards'].std():.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize imagination rollouts\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# Imagined rewards over horizon\n",
    "ax1 = axes[0, 0]\n",
    "steps = range(len(imagination_results['rewards']))\n",
    "for i in range(min(5, imagination_results['num_samples'])):\n",
    "    ax1.plot(steps, imagination_results['rewards'][:, i], alpha=0.5)\n",
    "ax1.set_xlabel(\"Time Step\")\n",
    "ax1.set_ylabel(\"Imagined Reward\")\n",
    "ax1.set_title(\"Imagined Reward Trajectories\")\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Mean and std of imagined rewards\n",
    "ax2 = axes[0, 1]\n",
    "mean_rewards = np.mean(imagination_results['rewards'], axis=1)\n",
    "std_rewards = np.std(imagination_results['rewards'], axis=1)\n",
    "ax2.plot(steps, mean_rewards, 'b-', linewidth=2, label='Mean')\n",
    "ax2.fill_between(steps, mean_rewards - std_rewards, mean_rewards + std_rewards, alpha=0.3)\n",
    "ax2.set_xlabel(\"Time Step\")\n",
    "ax2.set_ylabel(\"Reward\")\n",
    "ax2.set_title(\"Reward Uncertainty Over Imagination Horizon\")\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# State entropy over horizon\n",
    "ax3 = axes[1, 0]\n",
    "if 'state_entropy' in imagination_results:\n",
    "    ax3.plot(steps, imagination_results['state_entropy'], 'g-', linewidth=2)\n",
    "    ax3.set_xlabel(\"Time Step\")\n",
    "    ax3.set_ylabel(\"State Entropy\")\n",
    "    ax3.set_title(\"State Uncertainty Over Imagination Horizon\")\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "\n",
    "# Causal effect summary\n",
    "ax4 = axes[1, 1]\n",
    "top_effects = sorted(trace_result.layer_effects.items(), key=lambda x: abs(x[1]), reverse=True)[:5]\n",
    "layers = [e[0] for e in top_effects]\n",
    "effects = [e[1] for e in top_effects]\n",
    "ax4.barh(layers, effects, color=\"#9b59b6\")\n",
    "ax4.set_xlabel(\"Causal Effect\")\n",
    "ax4.set_title(\"Top 5 Causal Components for Reward Prediction\")\n",
    "ax4.grid(True, alpha=0.3, axis=\"x\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"dreamerv3_analysis.png\", dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Generate Interpretation Report\n",
    "\n",
    "Create a comprehensive report summarizing all findings from the DreamerV3 analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "from datetime import datetime\n",
    "\n",
    "# Generate comprehensive interpretation report\n",
    "interpretation_report = {\n",
    "    \"metadata\": {\n",
    "        \"timestamp\": datetime.now().isoformat(),\n",
    "        \"model\": \"DreamerV3 Atari\",\n",
    "        \"analysis_types\": [\"activation\", \"causal_tracing\", \"patching\", \"imagination\"]\n",
    "    },\n",
    "    \"architecture_summary\": {\n",
    "        \"components\": arch_info[\"components\"],\n",
    "        \"hookable_layers\": len(hookable_layers)\n",
    "    },\n",
    "    \"activation_analysis\": {\n",
    "        \"layer_statistics\": activation_data[\"statistics\"],\n",
    "        \"rssm_analysis\": {\n",
    "            \"stochastic_unique_values\": stoch_unique,\n",
    "            \"stochastic_entropy\": float(analyzer.compute_entropy(stoch_activations)),\n",
    "            \"deterministic_variance\": float(det_variance)\n",
    "        }\n",
    "    },\n",
    "    \"causal_tracing\": {\n",
    "        \"target_behavior\": trace_config.target_behavior,\n",
    "        \"top_causal_layers\": [(l, float(e)) for l, e in top_effects]\n",
    "    },\n",
    "    \"imagination_analysis\": {\n",
    "        \"horizon\": imagination_results['horizon'],\n",
    "        \"mean_reward\": float(imagination_results['rewards'].mean()),\n",
    "        \"reward_variance\": float(imagination_results['rewards'].std())\n",
    "    },\n",
    "    \"conclusions\": []\n",
    "}\n",
    "\n",
    "# Generate conclusions\n",
    "if trace_result.layer_effects.get(\"rssm.stochastic\", 0) > trace_result.layer_effects.get(\"rssm.deterministic\", 0):\n",
    "    interpretation_report[\"conclusions\"].append(\n",
    "        \"Stochastic states have stronger causal influence on reward prediction than deterministic states\"\n",
    "    )\n",
    "\n",
    "if imagination_results['horizon'] > 30:\n",
    "    interpretation_report[\"conclusions\"].append(\n",
    "        \"Model demonstrates long-horizon imagination capability (>30 steps)\"\n",
    "    )\n",
    "\n",
    "if det_variance > 0.1:\n",
    "    interpretation_report[\"conclusions\"].append(\n",
    "        \"Deterministic state carries significant information (high variance)\"\n",
    "    )\n",
    "\n",
    "# Save report\n",
    "with open(\"dreamerv3_case_study_report.json\", \"w\") as f:\n",
    "    json.dump(interpretation_report, f, indent=2)\n",
    "\n",
    "print(\"Interpretation Report Generated!\")\n",
    "print(\"=\"*60)\n",
    "print(\"\\nKey Findings:\")\n",
    "for i, conclusion in enumerate(interpretation_report[\"conclusions\"], 1):\n",
    "    print(f\"  {i}. {conclusion}\")\n",
    "\n",
    "print(\"\\nReport saved to dreamerv3_case_study_report.json\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Print full report\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"DREAMERV3 CASE STUDY - FULL REPORT\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "print(\"\\n1. ARCHITECTURE\")\n",
    "print(\"-\"*40)\n",
    "for component, details in arch_info[\"components\"].items():\n",
    "    print(f\"  {component}: {details}\")\n",
    "\n",
    "print(\"\\n2. ACTIVATION ANALYSIS\")\n",
    "print(\"-\"*40)\n",
    "print(f\"  RSSM stochastic entropy: {interpretation_report['activation_analysis']['rssm_analysis']['stochastic_entropy']:.4f}\")\n",
    "print(f\"  RSSM deterministic variance: {interpretation_report['activation_analysis']['rssm_analysis']['deterministic_variance']:.4f}\")\n",
    "\n",
    "print(\"\\n3. CAUSAL INFLUENCE\")\n",
    "print(\"-\"*40)\n",
    "for layer, effect in interpretation_report[\"causal_tracing\"][\"top_causal_layers\"][:3]:\n",
    "    print(f\"  {layer}: {effect:.4f}\")\n",
    "\n",
    "print(\"\\n4. IMAGINATION CAPABILITY\")\n",
    "print(\"-\"*40)\n",
    "print(f\"  Horizon: {interpretation_report['imagination_analysis']['horizon']} steps\")\n",
    "print(f\"  Mean reward: {interpretation_report['imagination_analysis']['mean_reward']:.4f}\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"Report files saved:\")\n",
    "print(\"  - dreamerv3_case_study_report.json\")\n",
    "print(\"  - activation_distributions.png\")\n",
    "print(\"  - causal_trace_results.png\")\n",
    "print(\"  - dreamerv3_analysis.png\")"
   ]
  }
 ],
