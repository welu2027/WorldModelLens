{
  "dashboard": {
    "id": null,
    "uid": "wml-overview",
    "title": "World Model Lens Overview",
    "tags": ["world_model_lens", "api"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(wml_http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "Request Latency (p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(wml_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Analysis Jobs",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "wml_analysis_jobs_total",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Analyses",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "wml_active_analyses",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "wml_memory_usage_bytes",
            "legendFormat": "Used",
            "refId": "A"
          },
          {
            "expr": "wml_memory_limit_bytes",
            "legendFormat": "Limit",
            "refId": "B"
          }
        ]
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "rate(wml_errors_total[5m])",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
